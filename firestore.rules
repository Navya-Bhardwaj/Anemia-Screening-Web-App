rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidTimestamp() {
      return request.time == request.time;
    }
    
    function isValidUserData() {
      return request.resource.data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.email == request.auth.token.email;
    }
    
    function isValidScreeningData() {
      return request.resource.data.keys().hasAll(['date', 'result', 'userId']) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.date is timestamp &&
             request.resource.data.result is map;
    }

    // Users collection rules
    match /users/{userId} {
      // Users can only read/write their own documents
      allow read, write: if isOwner(userId);
      
      // Create operation: must be authenticated and match their auth data
      allow create: if isAuthenticated() && 
                     isValidUserData() &&
                     isValidTimestamp();
      
      // Update operation: must be owner and can't change uid/email
      allow update: if isOwner(userId) &&
                     request.resource.data.uid == resource.data.uid &&
                     request.resource.data.email == resource.data.email;
      
      // Delete operation: only owner can delete their account
      allow delete: if isOwner(userId);
    }

    // Screenings collection rules
    match /screenings/{screeningId} {
      // Anyone can read if they own it
      allow read: if isAuthenticated() && 
                   request.auth.uid == resource.data.userId;
      
      // Create screening: must be authenticated and own the screening
      allow create: if isAuthenticated() && 
                     isValidScreeningData() &&
                     isValidTimestamp();
      
      // Update screening: only owner can update
      allow update: if isAuthenticated() && 
                     request.auth.uid == resource.data.userId;
      
      // Delete screening: only owner can delete
      allow delete: if isAuthenticated() && 
                     request.auth.uid == resource.data.userId;
    }

    // User screening history (subcollection)
    match /users/{userId}/screeningHistory/{historyId} {
      // Read/write only if user owns the parent document
      allow read, write: if isOwner(userId);
      
      // Create: must be authenticated and valid data
      allow create: if isOwner(userId) && 
                     request.resource.data.userId == userId &&
                     request.resource.data.date is timestamp;
      
      // Update/delete: only owner
      allow update, delete: if isOwner(userId);
    }

    // Doctor consultations collection
    match /doctorConsultations/{consultationId} {
      // Read: user can read their own consultations
      allow read: if isAuthenticated() && 
                   (request.auth.uid == resource.data.userId ||
                    request.auth.uid == resource.data.doctorId);
      
      // Create: must be authenticated and valid data
      allow create: if isAuthenticated() && 
                     request.resource.data.userId == request.auth.uid &&
                     request.resource.data.date is timestamp;
      
      // Update: user or doctor can update
      allow update: if isAuthenticated() && 
                     (request.auth.uid == resource.data.userId ||
                      request.auth.uid == resource.data.doctorId);
      
      // Delete: only user who created it
      allow delete: if isAuthenticated() && 
                     request.auth.uid == resource.data.userId;
    }

    // Public health data collection (read-only for authenticated users)
    match /publicHealthData/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // No public writes
    }

    // Admin collection (only admin users)
    match /admin/{docId} {
      allow read, write: if isAuthenticated() && 
                         request.auth.token.admin == true;
    }

    // System settings (admin only)
    match /settings/{docId} {
      allow read: if isAuthenticated(); // All authenticated users can read
      allow write: if isAuthenticated() && 
                   request.auth.token.admin == true;
    }

    // Analytics data (admin read, user write own data)
    match /analytics/{docId} {
      allow read: if isAuthenticated() && 
                   request.auth.token.admin == true;
      
      allow write: if isAuthenticated() && 
                     request.auth.uid == request.resource.data.userId;
    }

    // Chat messages (between users and doctors)
    match /chats/{chatId} {
      // Read: participants can read
      allow read: if isAuthenticated() && 
                   request.auth.uid in resource.data.participants;
      
      // Create: must be authenticated and be a participant
      allow create: if isAuthenticated() && 
                     request.auth.uid in request.resource.data.participants;
      
      // Update: participants can update
      allow update: if isAuthenticated() && 
                     request.auth.uid in resource.data.participants;
      
      // Delete: only creator or admin
      allow delete: if isAuthenticated() && 
                     (request.auth.uid == resource.data.createdBy ||
                      request.auth.token.admin == true);
    }

    // Messages subcollection under chats
    match /chats/{chatId}/messages/{messageId} {
      // Read: chat participants can read
      allow read: if isAuthenticated() && 
                   request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      
      // Create: participants can create messages
      allow create: if isAuthenticated() && 
                     request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                     request.resource.data.senderId == request.auth.uid &&
                     request.resource.data.timestamp is timestamp;
      
      // Update: only sender can update their own messages
      allow update: if isAuthenticated() && 
                     request.auth.uid == resource.data.senderId;
      
      // Delete: only sender or admin
      allow delete: if isAuthenticated() && 
                     (request.auth.uid == resource.data.senderId ||
                      request.auth.token.admin == true);
    }
  }
}
